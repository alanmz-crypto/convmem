#!/usr/bin/env bash
# convmem pre-push: reject WIP-pattern commit subjects targeting main.
# Install: bash scripts/install-git-hooks.sh
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
export PYTHONPATH="${ROOT}${PYTHONPATH:+:$PYTHONPATH}"
exec python3 -c "from git_hooks import main; raise SystemExit(main())" "$@"
