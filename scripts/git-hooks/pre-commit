#!/usr/bin/env bash
# convmem pre-commit: reject commits on main/master.
# Install: bash scripts/install-git-hooks.sh
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
export PYTHONPATH="${ROOT}${PYTHONPATH:+:$PYTHONPATH}"
exec python3 -c "from git_hooks import main; raise SystemExit(main())" pre-commit
