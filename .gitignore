processed.json
knowledge_units.jsonl
refine_stats.json
dedupe_queue.jsonl
link_queue.jsonl
refine.lock
watch.lock
refine_undo/

# Chroma persistence (if ever created inside the repo)
chroma/

# Local config (copy from config.example.toml)
config.toml
!.codex/config.toml.example

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.mypy_cache/

# Editor / OS
.DS_Store
*.swp
.venv/

# Cursor debug-mode logs (local runtime instrumentation artifacts)
.cursor/debug-*.log

# Handoff bundles (built locally; not committed)
handoff-tar/*.tar.gz
handoff-tar/*.manifest.txt
handoff-tar/*/
handoff-*.tar.gz
review-bundles/*/
review-bundles/*.tar.gz
.aider*

# Builder-reference staging extracts (local-only source slices)
staging/builder-reference/

# Accidental repo-root artifacts (never commit)
/convmem.db
/argparse
/json
/sys
# Agent worktree probe — must not package scripts/ for Pylint module names
scripts/__init__.py
