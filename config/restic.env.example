# Restic backup for the complete ConvMem Tier-1 data root.
# Copy to ~/.config/convmem/restic.env and chmod 600.
#
# Manual secret step (Ryan, once):
#   openssl rand -base64 32 > ~/.config/convmem/restic.password
#   chmod 600 ~/.config/convmem/restic.password
#   bash ~/Projects/convmem/scripts/setup-restic-chroma.sh
#
# Stale threshold (pinned): latest restic snapshot tagged convmem-data-v1 must
# cover CONVMEM_DATA_ROOT and have a snapshot time on the **same local calendar
# day** as now. Otherwise the gate runs `restic backup` before any live write.
# Fail-closed on any restic error. The snapshot also receives the legacy
# convmem-chroma tag so existing restore tooling can discover its Chroma child.

RESTIC_REPOSITORY=/home/lauer/.local/share/convmem-restic
RESTIC_PASSWORD_FILE=/home/lauer/.config/convmem/restic.password
CONVMEM_DATA_ROOT=/home/lauer/.local/share/convmem
CONVMEM_CHROMA_DIR=/home/lauer/.local/share/convmem/chroma

# Offsite copy target (removable USB). Same password as the local repo.
# Copied every 2h by systemd/convmem-restic-external.timer via
# scripts/restic-copy-external.sh. Non-fatal: skips when the drive is unplugged
# and never blocks the live-write gate. `convmem doctor` reports its freshness
# (restic_external: warn when stale, skip when unmounted).
RESTIC_EXTERNAL_REPOSITORY=/run/media/lauer/rxBUlauer-128Gfs/convmem-backups

# Offline copy of the password (the single secret that unlocks BOTH repos).
# Without a second copy, a Tier-2 config wipe of ~/.config/convmem orphans
# everything. Must live OFF this machine's config dir and NOT inside any restic
# repo/data root. Create/verify with scripts/backup-restic-password.sh <dest>;
# `convmem doctor` (restic_password_backup) warns until it is present + matches.
RESTIC_PASSWORD_BACKUP_FILE=/run/media/lauer/BIT-Brg-larch-7t/convmem-secrets/restic.password
